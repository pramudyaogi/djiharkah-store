# ==========================================
# SUPABASE ENVIRONMENT VARIABLES
# ==========================================

# 1. Masuk ke Dashboard Supabase -> Project Settings -> API
# 2. Salin URL di bagian "Project URL"
VITE_SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co

# 3. Salin kunci anon/public di bagian "Project API Keys"
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 4. Service Role Key dari bagian "Project API Keys"
# PENTING: JANGAN PERNAH MASUKKAN SERVICE ROLE KEY KE FRONTEND (React/Vite).
# Variabel ini hanya disiapkan jika nanti Anda butuh Edge Functions/Backend terpisah.
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
